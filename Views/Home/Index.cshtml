@model QL_ThuChiNoiBo.ViewModels.BudgetDashboardViewModel
@{
    ViewData["Title"] = "Dashboard Phân Tích";
}

<div class="mb-4 d-flex justify-content-between align-items-center">
    <div>
        <h4 class="mb-1 fw-bold text-dark"><i class="bi bi-speedometer2 text-primary me-2"></i>MIS Dashboard @DateTime.Now.Year</h4>
        <p class="text-muted mb-0 small">Báo cáo tổng quan tình hình thu chi nội bộ của doanh nghiệp</p>
    </div>
        
    <div class="d-flex gap-2">
        <a asp-action="XuatBaoCaoThang" asp-controller="ExportChotSo" asp-route-month="@DateTime.Now.Month" asp-route-year="@DateTime.Now.Year" class="btn btn-outline-success shadow-sm rounded-pill fw-bold hover-effect">
            <i class="bi bi-file-earmark-bar-graph-fill me-2 fs-5 align-middle"></i> Xuất Báo Cáo KQKD
        </a>
        <form id="chotSoForm" asp-action="XacNhanChotSo" asp-controller="ExportChotSo" asp-route-month="@DateTime.Now.Month" asp-route-year="@DateTime.Now.Year" method="post">
            @Html.AntiForgeryToken()
            <button type="button" onclick="chotSoAjax()" class="btn btn-danger shadow-sm rounded-pill fw-bold">
                <i class="bi bi-lock-fill me-2 fs-5 align-middle"></i> Chốt Sổ Kỳ Báo Cáo
            </button>
        </form>
    </div>

</div>

<!-- 4 Summary Cards -->
<div class="row g-4 mb-5 row-cols-1 row-cols-sm-2 row-cols-lg-3 row-cols-xl-5">
    <!-- Tổng Ngân Sách -->
    <div class="col">
        <div class="card border-0 shadow-sm rounded-4 h-100 bg-primary bg-opacity-10 position-relative overflow-hidden">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h6 class="text-primary fw-bold mb-0">TỔNG NGÂN SÁCH</h6>
                    <div class="bg-primary bg-opacity-25 rounded-circle p-2 d-flex align-items-center justify-content-center" style="width:48px;height:48px;">
                        <i class="bi bi-safe2-fill text-primary fs-4"></i>
                    </div>
                </div>
                <h3 class="fw-bold text-dark mb-0">@Model.TongNganSach.ToString("N0") <small class="text-muted fs-6">VNĐ</small></h3>
            </div>
            <div class="position-absolute opacity-25" style="top: -20px; right: -20px;">
                <i class="bi bi-safe2-fill text-primary" style="font-size: 8rem;"></i>
            </div>
        </div>
    </div>

        <!-- Tổng Đã Thu -->
    <div class="col">
        <div class="card border-0 shadow-sm rounded-4 h-100 bg-info bg-opacity-10 position-relative overflow-hidden">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h6 class="text-info fw-bold mb-0">TỔNG ĐÃ THU</h6>
                    <div class="bg-info bg-opacity-25 rounded-circle p-2 d-flex align-items-center justify-content-center" style="width:48px;height:48px;">
                        <i class="bi bi-wallet2 text-info fs-4"></i>
                    </div>
                </div>
                <h3 class="fw-bold text-dark mb-0">@Model.TongDaThu.ToString("N0") <small class="text-muted fs-6">VNĐ</small></h3>
            </div>
            <div class="position-absolute opacity-25" style="top: -20px; right: -20px;">
                <i class="bi bi-wallet2 text-info" style="font-size: 8rem;"></i>
            </div>
        </div>
    </div>

    <!-- Tổng Đã Chi -->
    <div class="col">
        <div class="card border-0 shadow-sm rounded-4 h-100 bg-success bg-opacity-10 position-relative overflow-hidden">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h6 class="text-success fw-bold mb-0">TỔNG ĐÃ CHI</h6>
                    <div class="bg-success bg-opacity-25 rounded-circle p-2 d-flex align-items-center justify-content-center" style="width:48px;height:48px;">
                        <i class="bi bi-cash-stack text-success fs-4"></i>
                    </div>
                </div>
                <h3 class="fw-bold text-dark mb-0">@Model.TongDaChi.ToString("N0") <small class="text-muted fs-6">VNĐ</small></h3>
            </div>
            <div class="position-absolute opacity-25" style="top: -20px; right: -20px;">
                <i class="bi bi-cash-stack text-success" style="font-size: 8rem;"></i>
            </div>
        </div>
    </div>

    <!-- Tiền Đang Treo -->
    <div class="col">
        <div class="card border-0 shadow-sm rounded-4 h-100 bg-warning bg-opacity-10 position-relative overflow-hidden">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h6 class="text-warning text-dark fw-bold mb-0">ĐANG TREO (CHỜ DUYỆT)</h6>
                    <div class="bg-warning bg-opacity-25 rounded-circle p-2 d-flex align-items-center justify-content-center" style="width:48px;height:48px;">
                        <i class="bi bi-hourglass-split text-warning fs-4"></i>
                    </div>
                </div>
                <h3 class="fw-bold text-dark mb-0">@Model.TongDangTreo.ToString("N0") <small class="text-muted fs-6">VNĐ</small></h3>
            </div>
            <div class="position-absolute opacity-25" style="top: -20px; right: -20px;">
                <i class="bi bi-hourglass-split text-warning" style="font-size: 8rem;"></i>
            </div>
        </div>
    </div>

    <!-- Số Dư Còn Lại -->
    <div class="col">
        <div class="card border-0 shadow-sm rounded-4 h-100 bg-info bg-opacity-10 position-relative overflow-hidden">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h6 class="text-info text-dark fw-bold mb-0">SỐ DƯ CÒN LẠI</h6>
                    <div class="bg-info bg-opacity-25 rounded-circle p-2 d-flex align-items-center justify-content-center" style="width:48px;height:48px;">
                        <i class="bi bi-wallet2 text-info fs-4"></i>
                    </div>
                </div>
                <h3 class="fw-bold text-dark mb-0">@Model.TongConLai.ToString("N0") <small class="text-muted fs-6">VNĐ</small></h3>
            </div>
            <div class="position-absolute opacity-25" style="top: -20px; right: -20px;">
                <i class="bi bi-wallet2 text-info" style="font-size: 8rem;"></i>
            </div>
        </div>
    </div>
</div>

<!-- Charts Section -->
<div class="row g-4 mb-5">
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-header bg-white border-bottom-0 pt-4 pb-0">
                <h6 class="fw-bold text-dark mb-0"><i class="bi bi-pie-chart-fill text-muted me-2"></i>Cơ cấu dòng tiền công ty</h6>
            </div>
            <div class="card-body d-flex justify-content-center align-items-center">
                <div style="height: 280px; width: 100%;">
                    <canvas id="doughnutChart"></canvas>
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-header bg-white border-bottom-0 pt-4 pb-0">
                <h6 class="fw-bold text-dark mb-0"><i class="bi bi-bar-chart-fill text-muted me-2"></i>Tình hình sử dụng ngân sách các chi nhánh - phòng ban</h6>
            </div>
            <div class="card-body">
                <div style="height: 280px; width: 100%;">
                    <canvas id="barChart"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Table Section -->
<div class="card border-0 shadow-sm rounded-4 mb-5">
    <div class="card-header bg-white border-bottom-0 pt-4 pb-2">
        <h6 class="fw-bold text-dark mb-0"><i class="bi bi-table text-muted me-2"></i>Bảng Phân Bổ Ngân Sách Chi Tiết Từng Phòng Ban</h6>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4 py-3 text-muted small fw-semibold">Tên Phòng Ban</th>
                        <th class="py-3 text-muted small fw-semibold text-end">Ngân Sách Cấp</th>
                        <th class="py-3 text-muted small fw-semibold text-end">Đã Thu</th>
                                <th class="py-3 text-muted small fw-semibold text-end">Đã Chi Tiêu</th>
                        <th class="py-3 text-muted small fw-semibold text-end">Giao Dịch Đang Treo</th>
                        <th class="py-3 text-muted small fw-semibold text-end">Số Dư Còn Lại</th>
                        <th class="py-3 text-muted small fw-semibold text-center pe-4">Trạng Thái An Toàn</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var dept in Model.DepartmentBudgets)
                    {
                        <tr>
                            <td class="ps-4 fw-bold text-dark">@dept.TenPhongBan</td>
                            <td class="text-end fw-medium">@dept.NganSach.ToString("N0")</td>
                            <td class="text-end text-success fw-bold">@dept.DaThu.ToString("N0")</td>
                            <td class="text-end text-danger fw-bold">@dept.DaChi.ToString("N0")</td>
                            <td class="text-end text-warning text-dark fw-medium">@dept.DangTreo.ToString("N0")</td>
                            <td class="text-end text-info fw-bold">@dept.ConLai.ToString("N0")</td>
                            <td class="text-center pe-4">
                                @if (dept.TyLeSuDung >= 80)
                                {
                                    <span class="badge bg-danger rounded-pill px-3 py-2 shadow-sm animate__animated animate__pulse animate__infinite">
                                        <i class="bi bi-exclamation-triangle-fill me-1"></i> Sắp vượt hạn mức
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 rounded-pill px-3 py-2">
                                        <i class="bi bi-shield-check-fill me-1"></i> An toàn
                                    </span>
                                }
                            </td>
                        </tr>
                    }
                    @if (!Model.DepartmentBudgets.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5 text-muted">Chưa có số liệu phòng ban.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const chartData = @Html.Raw(ViewBag.ChartDataJson);

            // Doughnut Chart Setup
            const ctxDoughnut = document.getElementById('doughnutChart').getContext('2d');
            new Chart(ctxDoughnut, {
                type: 'doughnut',
                data: {
                    labels: ['Đã Chi (\u20AB)', 'Đang Treo (\u20AB)', 'Còn Lại (\u20AB)'],
                    datasets: [{
                        data: [chartData.TongDaChi, chartData.TongDangTreo, chartData.TongConLai],
                        backgroundColor: [
                            '#198754', // success
                            '#ffc107', // warning
                            '#0dcaf0'  // info
                        ],
                        borderWidth: 0,
                        hoverOffset: 6
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { 
                            position: 'bottom',
                            labels: {
                                padding: 20,
                                font: { family: 'Inter', size: 12 }
                            }
                        },
                        tooltip: {
                            callbacks: {
                                label: function(context) {
                                    let label = context.label || '';
                                    if (label) { label += ': '; }
                                    if (context.parsed !== null) {
                                        label += new Intl.NumberFormat('vi-VN').format(context.parsed) + ' VNĐ';
                                    }
                                    return label;
                                }
                            }
                        }
                    },
                    cutout: '72%'
                }
            });

            // Bar Chart Setup
            const labelsBar = chartData.DepartmentBudgets.map(d => d.TenPhongBan);
            const nganSachData = chartData.DepartmentBudgets.map(d => d.NganSach);
            const daChiData = chartData.DepartmentBudgets.map(d => d.DaChi);

            const ctxBar = document.getElementById('barChart').getContext('2d');
            new Chart(ctxBar, {
                type: 'bar',
                data: {
                    labels: labelsBar,
                    datasets: [
                        {
                            label: 'Ngân Sách Cấp',
                            data: nganSachData,
                            backgroundColor: '#e9ecef',
                            borderRadius: 4,
                            barPercentage: 0.6
                        },
                        {
                            label: 'Tiền Đã Chi',
                            data: daChiData,
                            backgroundColor: '#0d6efd',
                            borderRadius: 4,
                            barPercentage: 0.6
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { 
                            position: 'top',
                            labels: {
                                font: { family: 'Inter', size: 12 }
                            }
                        },
                        tooltip: {
                            callbacks: {
                                label: function(context) {
                                    return context.dataset.label + ': ' + new Intl.NumberFormat('vi-VN').format(context.parsed.y) + ' VNĐ';
                                }
                            }
                        }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            grid: { borderDash: [4, 4], color: '#f8f9fa' },
                            ticks: {
                                callback: function(value) {
                                    if (value >= 1000000) return (value / 1000000) + ' Tr';
                                    return value;
                                },
                                font: { family: 'Inter' }
                            }
                        },
                        x: {
                            grid: { display: false },
                            ticks: { font: { family: 'Inter' } }
                        }
                    }
                }
            });
        });
    </script>
}

















<script>
    function chotSoAjax() {
        if (!confirm("Bạn có chắc chắn đóng băng dữ liệu tháng này và nảy số dư sang tháng sau? Khoảng 2 chế độ Download sẽ tự động bật!")) return;
        
        var form = document.getElementById("chotSoForm");
        var formData = new FormData(form);
        
        fetch(form.action, {
            method: "POST",
            body: formData
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                Swal.fire("Tuyệt vời!", data.message, "success");
                // Auto trigger excel download
                window.location.href = `/ExportChotSo/XuatBaoCaoThang?month=${data.month}&year=${data.year}`;
            } else {
                Swal.fire("Lỗi!", data.message, "error");
            }
        })
        .catch(err => {
            Swal.fire("Lỗi Cứng!", "Mất kết nối máy chủ", "error");
        });
    }
</script>

