@model QL_ThuChiNoiBo.ViewModels.ChangePasswordViewModel

@{
    ViewData["Title"] = "Đổi mật khẩu";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-header bg-white border-0 pt-4 pb-0 text-center">
                    <h4 class="fw-bold text-primary mb-0"><i class="bi bi-shield-lock-fill me-2"></i>Đổi Mật Khẩu</h4>
                    <p class="text-muted small mt-1">Bảo vệ tài khoản FinFlow của bạn</p>
                </div>
                <div class="card-body p-4">
                    <form asp-action="ChangePassword" method="post">
                        @Html.AntiForgeryToken()
                        
                        <div class="mb-3">
                            <label asp-for="CurrentPassword" class="form-label fw-semibold"></label>
                            <input asp-for="CurrentPassword" type="password" class="form-control rounded-3" placeholder="Nhập mật khẩu hiện tại" />
                            <span asp-validation-for="CurrentPassword" class="text-danger small"></span>
                        </div>
                        
                        <div class="mb-3">
                            <label asp-for="NewPassword" class="form-label fw-semibold"></label>
                            <input asp-for="NewPassword" type="password" class="form-control rounded-3" placeholder="Mật khẩu mới (ít nhất 6 ký tự)" />
                            <span asp-validation-for="NewPassword" class="text-danger small"></span>
                        </div>
                        
                        <div class="mb-4">
                            <label asp-for="ConfirmPassword" class="form-label fw-semibold"></label>
                            <input asp-for="ConfirmPassword" type="password" class="form-control rounded-3" placeholder="Nhập lại mật khẩu mới" />
                            <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                        </div>
                        
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary fw-bold py-2 rounded-3">CẬP NHẬT MẬT KHẨU</button>
                            <a asp-action="Index" asp-controller="Home" class="btn btn-light fw-bold py-2 rounded-3 text-muted">Hủy & Quay lại</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
