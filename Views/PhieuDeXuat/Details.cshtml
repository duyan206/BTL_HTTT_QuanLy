@model QL_ThuChiNoiBo.Models.PhieuDeXuat
@{
    ViewData["Title"] = "Chi Tiết Phiếu #" + Model.MaPhieu;
}

<div class="mb-4">
    <a asp-action="Index" class="text-decoration-none text-muted mb-3 d-inline-block hover-effect"><i class="bi bi-arrow-left me-1"></i> Quay lại danh sách</a>
    
    @if (Model.TrangThai == "Từ chối")
    {
        var rejectLog = Model.NhatKyDuyets?.OrderByDescending(n => n.ThoiGian).FirstOrDefault(n => n.HanhDong == "Từ chối" || n.HanhDong == "Từ Khước");
        if (rejectLog != null)
        {
            <div class="alert alert-danger shadow-sm border-0 mb-4 rounded-4" role="alert">
                <div class="d-flex align-items-center mb-2">
                    <i class="bi bi-exclamation-octagon-fill fs-3 me-3 text-danger"></i>
                    <h5 class="alert-heading mb-0 fw-bold">Phiếu bị từ chối bởi @rejectLog.NguoiXuLyNavigation?.HoTen</h5>
                </div>
                <hr class="border-danger opacity-25">
                <p class="mb-0"><strong>Lý do:</strong> @rejectLog.GhiChu</p>
            </div>
        }
    }

    <div class="d-flex justify-content-between align-items-center">
        <h4 class="fw-bold text-dark mb-0"><i class="bi bi-eye text-info me-2"></i>Chi Tiết Phiếu Đề Xuất #@Model.MaPhieu</h4>
        <div>
            @if (Model.TrangThai == "Nháp")
            {
                <a asp-action="Edit" asp-route-id="@Model.MaPhieu" class="btn btn-warning shadow-sm"><i class="bi bi-pencil me-1"></i> Chỉnh Sửa Phiếu</a>
            }
            @if (ViewBag.CanApprove == true)
            {
                <form asp-controller="DuyetPhieu" asp-action="Approve" method="post" class="d-inline">
                    <input type="hidden" name="id" value="@Model.MaPhieu" />
                    <button type="submit" class="btn btn-success shadow-sm ms-2"><i class="bi bi-check-circle-fill me-1"></i> Phê Duyệt</button>
                </form>
                <button type="button" class="btn btn-danger shadow-sm ms-2" data-bs-toggle="modal" data-bs-target="#rejectModal">
                    <i class="bi bi-x-circle-fill me-1"></i> Từ Chối
                </button>
            }
        </div>
    </div>
</div>

<!-- Lịch Sử Phê Duyệt -->
<div class="card border-0 shadow-sm rounded-4 mb-4">
    <div class="card-body p-4 p-md-5">
        <h5 class="fw-bold text-dark mb-4"><i class="bi bi-clock-history text-secondary me-2"></i>Lịch sử phê duyệt</h5>
        <div class="timeline position-relative ps-4 border-start border-2 border-primary border-opacity-25 pb-2">
            @if(Model.NhatKyDuyets != null && Model.NhatKyDuyets.Any())
            {
                foreach(var log in Model.NhatKyDuyets.OrderByDescending(n => n.ThoiGian))
                {
                    <div class="timeline-item position-relative mb-4">
                        <span class="position-absolute translate-middle p-2 bg-light border border-2 border-primary rounded-circle" style="left: -1.6rem;"></span>
                        <div class="bg-light p-3 rounded-4 shadow-sm">
                            <div class="d-flex justify-content-between mb-1">
                                <span class="fw-bold text-dark"><i class="bi bi-person-circle me-1"></i> @log.NguoiXuLyNavigation?.HoTen</span>
                                <span class="badge @(log.HanhDong == "Phê Duyệt" ? "bg-success" : "bg-danger")"><i class="bi @(log.HanhDong == "Phê Duyệt" ? "bi-check-lg" : "bi-x-lg") me-1"></i> @log.HanhDong</span>
                            </div>
                            <small class="text-muted d-block mb-2"><i class="bi bi-calendar3 me-1"></i> @log.ThoiGian?.ToString("dd/MM/yyyy HH:mm")</small>
                            @if (!string.IsNullOrEmpty(log.GhiChu))
                            {
                                <div class="p-2 bg-white border border-danger border-opacity-25 rounded text-dark fs-6 mt-2">
                                    <i class="bi bi-chat-left-quote text-danger me-1"></i> <em>@log.GhiChu</em>
                                </div>
                            }
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="text-muted"><i class="bi bi-info-circle me-1"></i> Chưa có lịch sử xử lý nào tại thời điểm này.</div>
            }
        </div>
    </div>
</div>

@if (ViewBag.CanApprove == true)
{
    <div class="modal fade" id="rejectModal" tabindex="-1">
        <div class="modal-dialog">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-danger text-white border-0">
            <h5 class="modal-title fw-bold"><i class="bi bi-exclamation-triangle-fill me-2"></i>Lý do từ chối</h5>
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form asp-controller="DuyetPhieu" asp-action="Reject" method="post">
                <div class="modal-body p-4 bg-light">
                    <input type="hidden" name="id" value="@Model.MaPhieu" />
                    <div class="mb-3">
                        <label for="reason" class="form-label fw-semibold text-dark">Ghi chú từ chối (Bắt buộc):</label>
                        <textarea name="reason" id="reason" class="form-control shadow-sm border-0" rows="4" required placeholder="Nhập chi tiết lỗi sai của phiếu để nhân viên viết lại..."></textarea>
                    </div>
                </div>
                <div class="modal-footer bg-light border-0">
                <button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-bs-dismiss="modal">Trở Về</button>
                <button type="submit" class="btn btn-danger shadow rounded-pill px-4"><i class="bi bi-send-x me-2"></i>Xác nhận Từ Chối</button>
                </div>
            </form>
        </div>
        </div>
    </div>
}

<div class="row g-4">
    <div class="col-lg-4">
        <div class="card shadow-sm border-0 mb-4 bg-light bg-opacity-50">
            <div class="card-body">
                @QL_ThuChiNoiBo.Utils.LoaiPhieuHelper.RenderBadge(Model.LoaiPhieu)
                <div class="mb-3">
                    <span class="text-muted small d-block mb-1">Trạng Thái:</span>
                    @if (Model.TrangThai == "Nháp") { <span class="badge bg-secondary">Nháp</span> }
                    else if (Model.TrangThai == "Chờ duyệt") { <span class="badge bg-warning text-dark"><i class="bi bi-hourglass-split me-1"></i>Chờ duyệt</span> }
                    else if (Model.TrangThai == "Đã duyệt") { <span class="badge bg-success"><i class="bi bi-check-circle me-1"></i>Đã duyệt</span> }
                    else { <span class="badge bg-danger"><i class="bi bi-x-circle me-1"></i>Từ chối</span> }
                </div>
                <div class="mb-3">
                    <span class="text-muted small d-block">Lý Do Đề Xuất:</span>
                    <p class="mb-0 text-dark fw-medium">@Model.LyDo</p>
                </div>
                <div class="mb-3">
                    <span class="text-muted small d-block">Tổng Tiền Đề Xuất:</span>
                    <h3 class="text-success fw-bold mb-0">@Model.TongTien.ToString("N0") <small class="text-muted fs-6">VNĐ</small></h3>
                </div>
                <hr class="text-muted" />
                <div class="mb-0">
                    <span class="text-muted small d-block">Ngày Tạo:</span>
                    <span class="text-dark fw-semibold"><i class="bi bi-clock me-1 text-muted"></i>@Model.NgayTao?.ToString("dd/MM/yyyy HH:mm")</span>
                </div>
            </div>
        </div>

        <div class="card shadow-sm border-0">
             <div class="card-header bg-white border-bottom-0 pt-4 pb-2">
                 <h6 class="fw-bold text-uppercase text-muted mb-0"><i class="bi bi-paperclip me-2"></i>Chứng Từ Đính Kèm</h6>
             </div>
             <div class="card-body pt-2">
                 @if(Model.ChungTuDinhKems.Any()) {
                     <ul class="list-group list-group-flush">
                         @foreach(var item in Model.ChungTuDinhKems) {
                             <li class="list-group-item bg-transparent px-0 d-flex justify-content-between align-items-center">
                                 <div class="text-truncate me-2">
                                     <i class="bi bi-file-earmark-text text-secondary me-2 fs-5"></i>
                                     <a href="@item.DuongDan" target="_blank" class="text-decoration-none fw-medium text-dark">@item.TenFile</a>
                                 </div>
                             </li>
                         }
                     </ul>
                 } else {
                     <div class="text-center py-3 text-muted">
                        <i class="bi bi-folder-x fs-3 d-block mb-1 opacity-50"></i>
                        <span class="small">Không có đính kèm</span>
                     </div>
                 }
             </div>
        </div>
    </div>

    <div class="col-lg-8">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-header bg-white border-bottom-0 pt-4 pb-2">
                <h6 class="fw-bold text-uppercase text-muted mb-0"><i class="bi bi-list-ul me-2"></i>Hạng Mục Chi Tiết Thực Hiện</h6>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive mt-2">
                    <table class="table align-middle mb-0 table-hover">
                        <thead class="bg-light">
                            <tr>
                                <th class="ps-4 text-muted small fw-semibold">STT</th>
                                <th class="text-muted small fw-semibold">Nội Dung / Hạng Mục</th>
                                <th class="text-center text-muted small fw-semibold">Số Tiền (VNĐ)</th>
                                <th class="text-muted small fw-semibold pe-4">Ghi Chú</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{ int stt = 1; }
                            @foreach(var ct in Model.ChiTietPhieus)
                            {
                                <tr>
                                    <td class="ps-4 text-secondary">@stt</td>
                                    <td class="text-dark fw-medium">@ct.HangMuc</td>
                                    <td class="text-center fw-bold text-success">@ct.SoTien.ToString("N0")</td>
                                    <td class="text-muted small pe-4">@(string.IsNullOrEmpty(ct.GhiChu) ? "-" : ct.GhiChu)</td>
                                </tr>
                                stt++;
                            }
                            @if (!Model.ChiTietPhieus.Any())
                            {
                                <tr>
                                    <td colspan="4" class="text-center py-4 text-muted">Không có dữ liệu chi tiết.</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot class="bg-light">
                            <tr>
                                <td colspan="2" class="text-end text-muted fw-bold pt-3 pb-3">Tổng Cộng:</td>
                                <td class="text-center fw-bold text-success fs-5 pt-3 pb-3">@Model.TongTien.ToString("N0")</td>
                                <td></td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

