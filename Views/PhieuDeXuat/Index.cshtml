@model IEnumerable<QL_ThuChiNoiBo.Models.PhieuDeXuat>
@{
    ViewData["Title"] = "Danh sách Phiếu Đề Xuất";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-1 fw-bold text-dark"><i class="bi bi-grid-fill text-primary me-2"></i>Phiếu Đề Xuất</h4>
        <p class="text-muted mb-0 small">Quản lý và theo dõi các đề xuất thu chi nội bộ của bạn</p>
    </div>
    <a asp-action="Create" class="btn btn-primary shadow-sm px-4"><i class="bi bi-plus-lg me-2"></i>Tạo Yêu Cầu</a>
</div>

<div class="card border-0 shadow-sm rounded-4">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th class="ps-4 py-3">Mã Phiếu</th>
                        <th class="py-3">Loại Phiếu</th>
                        <th class="py-3">Lý Do Đề Xuất</th>
                        <th class="py-3">Tổng Tiền</th>
                        <th class="py-3">Trạng Thái</th>
                        <th class="py-3">Ngày Tạo</th>
                        <th class="text-end pe-4 py-3">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4 fw-semibold text-secondary">#@item.MaPhieu</td>
                            <td>
                                @QL_ThuChiNoiBo.Utils.LoaiPhieuHelper.RenderBadge(item.LoaiPhieu)
                            </td>
                            <td style="max-width: 250px;" class="text-truncate text-dark" title="@item.LyDo">@item.LyDo</td>
                            <td class="fw-bold text-success">@item.TongTien.ToString("N0") <span class="text-muted fw-normal small">VNĐ</span></td>
                            <td>
                                @if (item.TrangThai == "Nháp")
                                {
                                    <span class="badge bg-secondary">Nháp</span>
                                }
                                else if (item.TrangThai == "Chờ duyệt")
                                {
                                    <span class="badge bg-warning text-dark"><i class="bi bi-hourglass-split me-1"></i>Chờ duyệt</span>
                                }
                                else if (item.TrangThai == "Đã duyệt")
                                {
                                    <span class="badge bg-success"><i class="bi bi-check-circle me-1"></i>Đã duyệt</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger"><i class="bi bi-x-circle me-1"></i>Từ chối</span>
                                }
                            </td>
                            <td class="text-muted small"><i class="bi bi-clock me-1"></i> @item.NgayTao?.ToString("dd/MM/yyyy HH:mm")</td>
                            <td class="text-end pe-4">
                                <a asp-action="Details" asp-route-id="@item.MaPhieu" class="btn btn-sm btn-light text-primary rounded-circle p-2" title="Xem chi tiết" style="width: 34px; height: 34px; display: inline-flex; align-items: center; justify-content: center;"><i class="bi bi-eye"></i></a>
                                @if (item.TrangThai == "Nháp")
                                {
                                    <a asp-action="Edit" asp-route-id="@item.MaPhieu" class="btn btn-sm btn-light text-warning rounded-circle p-2 ms-1" title="Sửa" style="width: 34px; height: 34px; display: inline-flex; align-items: center; justify-content: center;"><i class="bi bi-pencil"></i></a>
                                }
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center py-5">
                                <div class="text-muted">
                                    <i class="bi bi-inbox fs-1 d-block mb-3 opacity-50"></i>
                                    <h5>Chưa có phiếu đề xuất nào</h5>
                                    <p class="mb-0">Hãy bắt đầu bằng cách tạo một phiếu đề xuất mới.</p>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@if (ViewBag.TotalPages > 1)
{
    <nav class="mt-4">
        <ul class="pagination justify-content-center">
            <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                <a class="page-link" asp-action="Index" asp-route-page="@(ViewBag.CurrentPage - 1)">Trang trước</a>
            </li>
            @for (int i = 1; i <= ViewBag.TotalPages; i++)
            {
                <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="@i">@i</a>
                </li>
            }
            <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                <a class="page-link" asp-action="Index" asp-route-page="@(ViewBag.CurrentPage + 1)">Trang sau</a>
            </li>
        </ul>
    </nav>
}


